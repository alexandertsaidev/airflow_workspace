# Airflow 內部 DB（postgres 服務，port 5432）
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=your_password_here
AIRFLOW_DB_NAME=airflow

# Airflow Web UI 帳號
AIRFLOW_WWW_USER_USERNAME=admin
AIRFLOW_WWW_USER_PASSWORD=your_admin_password_here

# Airflow Keys
AIRFLOW_FERNET_KEY=your_fernet_key_here
AIRFLOW_SECRET_KEY=your_secret_key_here

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_password_here

# 額外 PostgreSQL（postgresql-db 服務，port 5433）
AIRFLOW_POSTGRES_USER=postgres
AIRFLOW_POSTGRES_PASSWORD=your_password_here
AIRFLOW_POSTGRES_DB=stock

# 其他
AIRFLOW_UID=50000